includes:
    - phar://phpstan.phar/conf/bleedingEdge.neon
    - vendor/spaze/phpstan-disallowed-calls/disallowed-dangerous-calls.neon
    - vendor/spaze/phpstan-disallowed-calls/disallowed-execution-calls.neon
    - vendor/spaze/phpstan-disallowed-calls/disallowed-insecure-calls.neon

parameters:
    tmpDir: .cache/phpstan

    paths:
        - src
        - tests

    level: max

    type_coverage:
        return: 100
        param: 100
        property: 100
        constant: 0
        declare: 100

    type_perfect:
        null_over_false: true
        no_mixed: false
        narrow_param: false
        narrow_return: true

    cognitive_complexity:
        class: 80
        function: 20

    strictRules:
        allRules: true

    editorUrl: 'phpstorm://open?file=%%file%%&line=%%line%%'

    treatPhpDocTypesAsCertain: false

    ignoreErrors:
        -
            identifier: trait.unused
            reportUnmatched: false

        # Eloquent\Builder is the canonical return for query helpers; the
        # generic parameter (Builder<self>) lives in PHPDoc since PHP has
        # no native generic return syntax. typePerfect's "more specific"
        # demand is unsatisfiable for this case.
        -
            identifier: typePerfect.narrowReturnObjectType
            path: src/Models/
            reportUnmatched: false

        # The service-provider intentionally references the
        # `X402\Laravel\Detection\BotDetector` deprecated class to wire
        # its alias-shim binding. The wrapper class file (src/Detection/
        # BotDetector.php) is the deprecation shim itself and similarly
        # references upstream classes by design. Both BC affordances drop
        # in 0.6.0 along with the deprecated class.
        -
            identifier: classConstant.deprecatedClass
            path: src/X402ServiceProvider.php
            reportUnmatched: false
        -
            identifier: method.deprecatedClass
            path: src/X402ServiceProvider.php
            reportUnmatched: false
        -
            identifier: new.deprecatedClass
            path: src/X402ServiceProvider.php
            reportUnmatched: false
        -
            identifier: return.deprecatedClass
            path: src/X402ServiceProvider.php
            reportUnmatched: false

        -
            identifier: method.notFound
            path: tests/
            reportUnmatched: false
        -
            identifier: method.internalClass
            path: tests/
            reportUnmatched: false
        -
            identifier: method.nonObject
            path: tests/
            reportUnmatched: false
        -
            identifier: staticMethod.dynamicCall
            path: tests/
            reportUnmatched: false
        -
            identifier: classConstant.internalClass
            path: tests/
            reportUnmatched: false
        # pest-plugin-arch's ArchExpectation interface is marked @internal but
        # the fluent helpers (ignoring, etc.) are the user-facing API.
        -
            identifier: method.internalInterface
            path: tests/Arch/
            reportUnmatched: false
